# Canonical URL for SEO (optional). On Vercel production, the custom domain is detected automatically.
# Set this for local builds or if metadata should always use a fixed host (e.g. https://tjfit.org).
NEXT_PUBLIC_SITE_URL=https://tjfit.org

# Google Search Console — HTML tag method: verification token, or full "google-site-verification=..." string.
GOOGLE_SITE_VERIFICATION=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin (server-side only - never use NEXT_PUBLIC_ for these)
# Admin email(s) - comma-separated. Users with these emails get full admin access.
ADMIN_EMAILS=admin@yourdomain.com

# TJAI (server-side only - never use NEXT_PUBLIC_)
# OpenAI API key for TJAI plan generation (GPT-4o). Get it from platform.openai.com/api-keys
OPENAI_API_KEY=
# Claude API key (used for blog generation and AI chat features). Get it from console.anthropic.com.
ANTHROPIC_API_KEY=

# Email — Resend (server-side only). Required for transactional emails (welcome, renewal, newsletters).
# Get your key at https://resend.com
RESEND_API_KEY=
# Secret used to sign unsubscribe tokens in newsletter emails (any random string).
EMAIL_UNSUBSCRIBE_SECRET=

# Coach terms of use version (bump to force re-acceptance for coaches only).
COACH_TERMS_VERSION=1.0

# Payments (server-only). resolvePaymentBackend() picks the adapter; create-order returns clientFlow.
# Live checkout: Paddle Billing — use PAYMENT_PROVIDER=paddle (or live as an alias), plus Paddle env vars below.
# PAYMENT_PROVIDER: unset + ALLOW_TEST_CHECKOUT=true → test mode. Use none|off to disable checkout.
# PAYMENT_PROVIDER=paddle
ALLOW_TEST_CHECKOUT=false
#
# Paddle Billing (https://developer.paddle.com)
# Server: create transaction + verify webhooks. Client: initializePaddle({ environment, token }).
PADDLE_API_KEY=
# Webhook signing secret from Paddle → Developer tools → Notifications → your destination
PADDLE_WEBHOOK_SECRET=
# sandbox | production (must match your Paddle dashboard mode)
PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
# Optional short alias for client Paddle.js (same values as above)
NEXT_PUBLIC_PADDLE_ENV=production
# Seller / default checkout client token (public — safe in NEXT_PUBLIC_)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# JSON map: program slug → Paddle catalog price id (pri_…), e.g. {"gym-mass-builder-12w":"pri_xxx"}
PADDLE_PRICE_MAP=
# Optional: single pri_… used when a slug is not in the map
PADDLE_DEFAULT_PRICE_ID=
# Optional: Paddle discount id (dsc_…) applied when the order has any TJFit discount (wallet or promo below)
PADDLE_WALLET_DISCOUNT_ID=
# Global promo codes (any logged-in user). Must match the % on PADDLE_WALLET_DISCOUNT_ID (dsc_…) in Paddle.
# Option A — JSON (can be awkward in some host UIs):
# CHECKOUT_PROMO_CODES={"JOSEPH1407":99}
CHECKOUT_PROMO_CODES=
# Option B — no JSON (recommended on Vercel): comma-separated CODE:PERCENT
# CHECKOUT_PROMO_PAIRS=JOSEPH1407:99
CHECKOUT_PROMO_PAIRS=
# Option C — single code as two plain vars:
# CHECKOUT_PROMO_CODE=JOSEPH1407
# CHECKOUT_PROMO_PERCENT=99
CHECKOUT_PROMO_CODE=
CHECKOUT_PROMO_PERCENT=
# Server-only: set true on Vercel preview/staging for verbose [paddle:debug] logs (no secrets / no raw bodies)
PADDLE_DEBUG_LOG=false

# Membership subscription price IDs (Paddle Billing — server and client)
# These should match the current public pricing:
# Pro = $6/mo or $60/year
# Apex = $10/mo or $100/year
# Find these in your Paddle dashboard under Catalog → Prices
NEXT_PUBLIC_PADDLE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PADDLE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_PADDLE_APEX_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PADDLE_APEX_ANNUAL_PRICE_ID=

# Marketing pixels (optional — TrackingScripts loads only when set; wire CMP/consent before production ads)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Sentry (optional - errors are no-op if not set)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
